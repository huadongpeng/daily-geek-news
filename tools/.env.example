# Easton Radar local environment
# Usage:
#   set -a
#   source tools/.env
#   set +a
#
# Fill values inside the quotes. Keep tools/.env local; it is ignored by Git.

# Required: DeepSeek text generation
DEEPSEEK_API_KEY=""
DEEPSEEK_FLASH_MODEL="deepseek-v4-flash"
DEEPSEEK_FLASH_THINKING="disabled"
DEEPSEEK_FLASH_REASONING_EFFORT="low"
DEEPSEEK_PRO_MODEL="deepseek-v4-pro"
DEEPSEEK_PRO_THINKING="enabled"
DEEPSEEK_PRO_REASONING_EFFORT="max"

# Optional: web search for evidence research (Tavily preferred, DDGS fallback)
TAVILY_API_KEY=""

# Optional: article cover image generation
SILICONFLOW_API_KEY=""
COVER_IMAGE_MODEL="Kwai-Kolors/Kolors"
SOCIAL_IMAGE_MODEL="Kwai-Kolors/Kolors"
SOCIAL_IMAGE_STEPS="28"
ALLOW_POLLINATIONS_COVER="true"

# Optional: email delivery for Xiaohongshu + video material packages
EMAIL_FROM=""
EMAIL_PASSWORD=""
EMAIL_TO="huadongpeng@outlook.com"
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT=""

# Optional: Telegram notification
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TG_THREAD_BRIEFING=""
TG_THREAD_AI=""
TG_THREAD_ARBITRAGE=""
TG_THREAD_CROSS=""
TG_THREAD_MACRO=""

# Optional: Reddit authenticated feed access
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USER_AGENT="script:easton-radar:4.0 (by /u/easton-radar)"

# Optional: search engine push
INDEXNOW_KEY="hdop-indexnow-key"
BAIDU_PUSH_TOKEN=""

# Optional: prompt/config overrides
PERSONA_PATH=""
RESEARCH_SKILL_PATH=""
WRITING_SKILL_PATH=""
XHS_PERSONA="快35岁的程序员，用AI系统化构建副业退路。真实经历：失业330天→法院起诉→重新就业。不教你用AI，只展示AI怎么帮我活下去。关注我看真实折腾日记，不打鸡血。"
XHS_PERSONA_PATH=""
