# ============================================================
# 腾讯云服务器环境变量配置
# 复制此文件为 tools/.env 并填入真实值：
#   cp tools/.env.example tools/.env
#   chmod 600 tools/.env
#   source tools/.env
# ============================================================

# --- 微信公众号（mp.weixin.qq.com → 设置与开发 → 基本配置）---
export WECHAT_APPID="wx你的AppID"
export WECHAT_APPSECRET="你的AppSecret"

# --- 文章作者署名（显示在公众号文章中）---
export WECHAT_AUTHOR="Easton Hua"

# --- DeepSeek API Key（微信文章润色）---
# 获取: https://platform.deepseek.com → API Keys
export DEEPSEEK_API_KEY="sk-你的DeepSeekKey"

# --- 通义万相 API Key（封面图生成，200张/月免费）---
# 获取: https://dashscope.console.aliyun.com → API-KEY 管理
export DASHSCOPE_API_KEY="sk-你的阿里百炼Key"

# --- 智谱 CogView API Key（封面图备选引擎，100张/月免费）---
# 获取: https://open.bigmodel.cn → API Keys
export ZHIPU_API_KEY="你的智谱Key"

# --- Git 仓库路径（一般不需要改）---
export GIT_REPO_DIR="/ws/web/daily-geek-news"
