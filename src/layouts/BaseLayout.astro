---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?:        string;
  description?:  string;
  ogImage?:      string;
  canonicalURL?: string;
  jsonLd?:       Record<string, unknown> | Record<string, unknown>[];
}

const {
  title       = 'hdop家 · 老花',
  description = '一个中年小公司技术经理的个人情报雷达：追一手信息、筛有价值的变化，写给自己看的简讯和深度文章。',
  ogImage     = '/og-default.jpg',
  jsonLd,
} = Astro.props;

const canonicalURL = Astro.props.canonicalURL ?? new URL(Astro.url.pathname, Astro.site).href;
const siteTitle    = title.includes('hdop家') ? title : `${title} · hdop家`;
const ogImageAbs   = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{siteTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph / WeChat sharing -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:image"       content={ogImageAbs} />
  <meta property="og:site_name"   content="hdop家" />
  <meta property="og:locale"      content="zh_CN" />

  <!-- Twitter / X card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={siteTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageAbs} />

  <!-- RSS autodiscovery -->
  <link rel="alternate" type="application/rss+xml" title="hdop家 RSS" href="/rss.xml" />

  <!-- Google AdSense Auto Ads -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4007535026028552" crossorigin="anonymous"></script>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- WebSite JSON-LD (site-wide, helps AI crawlers index authorship) -->
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify({
    "@context":"https://schema.org","@type":"WebSite",
    "name":"hdop家","url":"https://www.huadongpeng.com",
    "description":"一个中年小公司技术经理的个人情报雷达",
    "inLanguage":"zh-CN",
    "author":{"@type":"Person","name":"Easton Hua","alternateName":"老花","url":"https://www.huadongpeng.com/about/"}
  })}</script>`} />

  <!-- JSON-LD (injected by PostLayout when present; accepts single object or array) -->
  {jsonLd && (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).map(schema => (
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
  ))}
</head>
<body>
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
</body>
</html>
