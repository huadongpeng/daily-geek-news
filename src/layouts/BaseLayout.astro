---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?:        string;
  description?:  string;
  ogImage?:      string;
  canonicalURL?: string;
  jsonLd?:       Record<string, unknown> | Record<string, unknown>[];
}

const {
  title       = 'hdopе®¶ В· иҖҒиҠұ',
  description = 'дёҖдёӘдёӯе№ҙе°Ҹе…¬еҸёжҠҖжңҜз»ҸзҗҶзҡ„дёӘдәәжғ…жҠҘйӣ·иҫҫпјҡиҝҪдёҖжүӢдҝЎжҒҜгҖҒзӯӣжңүд»·еҖјзҡ„еҸҳеҢ–пјҢеҶҷз»ҷиҮӘе·ұзңӢзҡ„з®Җи®Ҝе’Ңж·ұеәҰж–Үз« гҖӮ',
  ogImage     = '/og-default.svg',
  jsonLd,
} = Astro.props;

const canonicalURL = Astro.props.canonicalURL ?? new URL(Astro.url.pathname, Astro.site).href;
const siteTitle    = title.includes('hdopе®¶') ? title : `${title} В· hdopе®¶`;
const ogImageAbs   = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="google-adsense-account" content="ca-pub-4007535026028552" />
  <!-- зҷҫеәҰжҗңзҙўиө„жәҗе№іеҸ° вҖ” з”іиҜ·еҗҺжӣҝжҚў BAIDU_VERIFY_CODE -->
  <meta name="baidu-site-verification" content="codeva-yNSx2HYKbG" />

  <title>{siteTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph / WeChat sharing -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:image"       content={ogImageAbs} />
  <meta property="og:site_name"   content="hdopе®¶" />
  <meta property="og:locale"      content="zh_CN" />

  <!-- Twitter / X card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={siteTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageAbs} />

  <!-- RSS autodiscovery -->
  <link rel="alternate" type="application/rss+xml" title="hdopе®¶ RSS" href="/rss.xml" />

  <!-- Google AdSense Auto Ads -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4007535026028552" crossorigin="anonymous"></script>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-N4HZZC9JQ8"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-N4HZZC9JQ8');
  </script>

  <!-- WebSite JSON-LD (site-wide, helps AI crawlers index authorship) -->
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify({
    "@context":"https://schema.org","@type":"WebSite",
    "name":"hdopе®¶","url":"https://www.huadongpeng.com",
    "description":"дёҖдёӘдёӯе№ҙе°Ҹе…¬еҸёжҠҖжңҜз»ҸзҗҶзҡ„дёӘдәәжғ…жҠҘйӣ·иҫҫ",
    "inLanguage":"zh-CN",
    "author":{"@type":"Person","name":"Easton Hua","alternateName":"иҖҒиҠұ","url":"https://www.huadongpeng.com/about/"}
  })}</script>`} />

  <!-- JSON-LD (injected by PostLayout when present; accepts single object or array) -->
  {jsonLd && (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).map(schema => (
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
  ))}
</head>
<body>
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
</body>
</html>
