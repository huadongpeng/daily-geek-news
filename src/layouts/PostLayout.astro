---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  frontmatter: CollectionEntry<'blog'>['data'];
  postId: string;        // Astro 5 post.id, e.g. "ai-tools/investigation-xxx"
  markdownBody?: string;
  prevPost?: CollectionEntry<'blog'> | null;
  nextPost?: CollectionEntry<'blog'> | null;
}

const { frontmatter, postId, markdownBody = '', prevPost, nextPost } = Astro.props;
const { title, date, description, cover, categories, tags, sources = [], wordCount = 0 } = frontmatter;
const updated = frontmatter.updated ?? date;

const CAT_LABELS: Record<string, string> = {
  'ai-tools':       'AI 工具前线',
  'side-hustle':    '副业实验室',
  'overseas':       '出海信号',
  'life-signal':    '生活信号',
  'daily-briefing': '每日简讯',
};

const cat        = categories?.[0] ?? '';
const catLabel   = CAT_LABELS[cat] ?? cat;
const dateStr    = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'Asia/Shanghai',
});
const canonURL   = new URL(`/blog/${postId}/`, Astro.site).href;

// BreadcrumbList for article pages
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页',    item: 'https://www.huadongpeng.com' },
    { '@type': 'ListItem', position: 2, name: catLabel, item: new URL(`/categories/${cat}/`, Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title,    item: canonURL },
  ],
};
const ogImageAbs = cover
  ? (cover.startsWith('http') ? cover : new URL(cover, Astro.site).href)
  : new URL('/og-default.svg', Astro.site).href;

// ── Schema.org BlogPosting JSON-LD ───────────────────────────
// The `citation` array lets Perplexity / ChatGPT Search trace every
// fact back to its primary source — core to AI SEO.
const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type':    'BlogPosting',
  headline:   title,
  ...(description && { description }),
  datePublished: date.toISOString(),
  dateModified:  updated.toISOString(),
  url:           canonURL,
  image:         ogImageAbs,
  inLanguage:    'zh-CN',
  author: {
    '@type':        'Person',
    name:           'Easton Hua',
    alternateName:  '老花',
    url:            'https://www.huadongpeng.com/about/',
  },
  publisher: {
    '@type': 'Organization',
    name:    'hdop家',
    url:     'https://www.huadongpeng.com',
    logo: {
      '@type': 'ImageObject',
      url:     new URL('/favicon.svg', Astro.site).href,
    },
  },
  ...(tags?.length && { keywords: tags.join(', ') }),
  ...(sources.length > 0 && {
    citation: sources.map(s => ({
      '@type': 'CreativeWork',
      name:    s.name,
      url:     s.url,
    })),
  }),
};

// 300 CJK chars/min is a typical Chinese reading speed benchmark
const readMins = wordCount > 0 ? Math.max(1, Math.round(wordCount / 300)) : null;
const sourceLines = sources.length > 0
  ? sources.map((source) => `- ${source.name}: ${source.url}`)
  : ['- 正文内已标注来源'];
const copyMarkdownText = [
  `# ${title}`,
  '',
  markdownBody.trim(),
  '',
  '---',
  '',
  `原文链接：${canonURL}`,
  '',
  '信息来源：',
  ...sourceLines,
  '',
  '转载说明：本文由 hdop家 · 老花（Easton Hua）发布。转载请保留作者署名、原文链接和信息来源；商业转载或改编请先联系作者。',
].join('\n').trim() + '\n';
const copyMarkdownJson = JSON.stringify(copyMarkdownText).replace(/</g, '\\u003c');
---

<BaseLayout
  title={title}
  description={description}
  ogImage={cover || '/og-default.svg'}
  canonicalURL={canonURL}
  jsonLd={[jsonLd, breadcrumb]}
>
  <div class="wrap">

    <header class="article-header">
      <div class="article-meta">
        {catLabel && <span class="tag">{catLabel}</span>}
        <time class="article-date" datetime={date.toISOString()}>{dateStr}</time>
        {readMins && <span class="article-date">· 约 {readMins} 分钟</span>}
      </div>
      <h1 class="article-title">{title}</h1>
      {description && <p class="article-desc">{description}</p>}
    </header>

    {cover && (
      <div class="article-cover">
        <img
          src={cover}
          alt={title}
          width="1024"
          height="576"
          loading="eager"
          decoding="async"
        />
      </div>
    )}

    {/*
      广告位 A — 文章内容前（横幅/矩形）
      申请通过后：替换 pub-XXXXXXXXXXXXXXXXX 和 data-ad-slot 值，删除注释
    */}
    {/* <ins class="adsbygoogle ad-article-top"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXXXX"
         data-ad-slot="AAAAAAAAAA"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script> */}

    <div class="article-actions">
      <button class="copy-md-button" type="button" data-copy-markdown>
        复制 Markdown 正文
      </button>
      <span class="copy-md-status" data-copy-status role="status" aria-live="polite"></span>
    </div>
    <script type="application/json" id="copy-markdown-payload" set:html={copyMarkdownJson}></script>

    <article class="prose">
      <slot />
    </article>

    <script is:inline>
      (() => {
        const prose = document.querySelector('.prose');
        if (!prose) return;
        const splitText = (text) => {
          const parts = text.match(/[^。！？!?；;，,、]+[。！？!?；;，,、]?/g) || [text];
          const chunks = [];
          let current = '';
          for (const part of parts) {
            const next = current + part;
            if (current && next.length > 120) {
              chunks.push(current.trim());
              current = part;
            } else {
              current = next;
            }
          }
          if (current.trim()) chunks.push(current.trim());
          return chunks;
        };
        for (const paragraph of Array.from(prose.querySelectorAll('p'))) {
          if (paragraph.children.length || (paragraph.textContent || '').trim().length < 150) continue;
          const chunks = splitText(paragraph.textContent || '');
          if (chunks.length < 2) continue;
          const replacements = chunks.map((chunk) => {
            const p = document.createElement('p');
            p.textContent = chunk;
            return p;
          });
          paragraph.replaceWith(...replacements);
        }
      })();
    </script>

    <script is:inline>
      (() => {
        const button = document.querySelector('[data-copy-markdown]');
        const status = document.querySelector('[data-copy-status]');
        const payload = document.getElementById('copy-markdown-payload');
        if (!button || !payload) return;

        let text = '';
        try {
          text = JSON.parse(payload.textContent || '""');
        } catch {
          text = payload.textContent || '';
        }

        let statusTimer = 0;
        const setStatus = (message) => {
          if (!status) return;
          status.textContent = message;
          window.clearTimeout(statusTimer);
          statusTimer = window.setTimeout(() => {
            status.textContent = '';
          }, 2200);
        };

        const fallbackCopy = () => {
          const textarea = document.createElement('textarea');
          textarea.value = text;
          textarea.setAttribute('readonly', '');
          textarea.style.position = 'fixed';
          textarea.style.left = '-9999px';
          document.body.appendChild(textarea);
          textarea.select();
          const ok = document.execCommand('copy');
          textarea.remove();
          if (!ok) throw new Error('copy command failed');
        };

        button.addEventListener('click', async () => {
          try {
            if (navigator.clipboard && window.isSecureContext) {
              await navigator.clipboard.writeText(text);
            } else {
              fallbackCopy();
            }
            setStatus('已复制');
          } catch {
            setStatus('复制失败，请手动选择正文');
          }
        });
      })();
    </script>

    {/*
      广告位 B — 文章内容后（效果通常最好）
      申请通过后：替换 pub-XXXXXXXXXXXXXXXXX 和 data-ad-slot 值，删除注释
    */}
    {/* <ins class="adsbygoogle ad-article-bottom"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXXXX"
         data-ad-slot="BBBBBBBBBB"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script> */}

    {sources.length > 0 && (
      <aside class="sources" aria-label="信息来源">
        <p class="sources-heading">信息来源</p>
        <ul class="sources-list">
          {sources.map(s => (
            <li>
              <a href={s.url} target="_blank" rel="noopener noreferrer">{s.name}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    {(prevPost || nextPost) && (
      <nav class="post-nav" aria-label="相邻文章">
        {prevPost ? (
          <a href={`/blog/${prevPost.id}/`} rel="prev">
            <span>上一篇</span>
            <strong>{prevPost.data.title}</strong>
          </a>
        ) : <div></div>}
        {nextPost ? (
          <a href={`/blog/${nextPost.id}/`} rel="next">
            <span>下一篇</span>
            <strong>{nextPost.data.title}</strong>
          </a>
        ) : <div></div>}
      </nav>
    )}

  </div>
</BaseLayout>
