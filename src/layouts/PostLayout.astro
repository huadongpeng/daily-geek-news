---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  frontmatter: CollectionEntry<'blog'>['data'];
  postId: string;        // Astro 5 post.id, e.g. "ai-tools/investigation-xxx"
  prevPost?: CollectionEntry<'blog'> | null;
  nextPost?: CollectionEntry<'blog'> | null;
}

const { frontmatter, postId, prevPost, nextPost } = Astro.props;
const { title, date, description, cover, categories, tags, sources = [], wordCount = 0 } = frontmatter;
const updated = frontmatter.updated ?? date;

const CAT_LABELS: Record<string, string> = {
  'ai-tools':       'AI 工具前线',
  'side-hustle':    '副业实验室',
  'overseas':       '出海信号',
  'life-signal':    '生活信号',
  'daily-briefing': '每日简讯',
};

const cat        = categories?.[0] ?? '';
const catLabel   = CAT_LABELS[cat] ?? cat;
const dateStr    = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const canonURL   = new URL(`/blog/${postId}/`, Astro.site).href;

// BreadcrumbList for article pages
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页',    item: 'https://www.huadongpeng.com' },
    { '@type': 'ListItem', position: 2, name: catLabel, item: new URL(`/categories/${cat}/`, Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title,    item: canonURL },
  ],
};
const ogImageAbs = cover
  ? (cover.startsWith('http') ? cover : new URL(cover, Astro.site).href)
  : new URL('/og-default.svg', Astro.site).href;

// ── Schema.org BlogPosting JSON-LD ───────────────────────────
// The `citation` array lets Perplexity / ChatGPT Search trace every
// fact back to its primary source — core to AI SEO.
const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type':    'BlogPosting',
  headline:   title,
  ...(description && { description }),
  datePublished: date.toISOString(),
  dateModified:  updated.toISOString(),
  url:           canonURL,
  image:         ogImageAbs,
  inLanguage:    'zh-CN',
  author: {
    '@type':        'Person',
    name:           'Easton Hua',
    alternateName:  '老花',
    url:            'https://www.huadongpeng.com/about/',
  },
  publisher: {
    '@type': 'Organization',
    name:    'hdop家',
    url:     'https://www.huadongpeng.com',
    logo: {
      '@type': 'ImageObject',
      url:     new URL('/favicon.svg', Astro.site).href,
    },
  },
  ...(tags?.length && { keywords: tags.join(', ') }),
  ...(sources.length > 0 && {
    citation: sources.map(s => ({
      '@type': 'CreativeWork',
      name:    s.name,
      url:     s.url,
    })),
  }),
};

// 300 CJK chars/min is a typical Chinese reading speed benchmark
const readMins = wordCount > 0 ? Math.max(1, Math.round(wordCount / 300)) : null;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={cover || '/og-default.svg'}
  canonicalURL={canonURL}
  jsonLd={[jsonLd, breadcrumb]}
>
  <div class="wrap">

    <header class="article-header">
      <div class="article-meta">
        {catLabel && <span class="tag">{catLabel}</span>}
        <time class="article-date" datetime={date.toISOString()}>{dateStr}</time>
        {readMins && <span class="article-date">· 约 {readMins} 分钟</span>}
      </div>
      <h1 class="article-title">{title}</h1>
      {description && <p class="article-desc">{description}</p>}
    </header>

    {cover && (
      <div class="article-cover">
        <img
          src={cover}
          alt={title}
          width="1024"
          height="576"
          loading="eager"
          decoding="async"
        />
      </div>
    )}

    {/*
      广告位 A — 文章内容前（横幅/矩形）
      申请通过后：替换 pub-XXXXXXXXXXXXXXXXX 和 data-ad-slot 值，删除注释
    */}
    {/* <ins class="adsbygoogle ad-article-top"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXXXX"
         data-ad-slot="AAAAAAAAAA"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script> */}

    <article class="prose">
      <slot />
    </article>

    <div class="copy-tools" data-copy-tools hidden>
      <button type="button" class="copy-button" data-copy-toutiao>复制今日头条正文</button>
      <span class="copy-status" data-copy-status></span>
    </div>

    <script is:inline>
      (() => {
        const params = new URLSearchParams(window.location.search);
        const enabled = params.has('toutiao') || params.has('copy');
        const tools = document.querySelector('[data-copy-tools]');
        const button = document.querySelector('[data-copy-toutiao]');
        const status = document.querySelector('[data-copy-status]');
        if (!enabled || !tools || !button) return;
        tools.hidden = false;

        const setStatus = (text) => {
          if (!status) return;
          status.textContent = text;
          window.setTimeout(() => {
            status.textContent = '';
          }, 1800);
        };

        const copyArticle = async () => {
          const title = document.querySelector('.article-title')?.textContent?.trim() || '';
          const body = document.querySelector('.prose')?.innerText?.trim() || '';
          const text = [title, body].filter(Boolean).join('\n\n').replace(/\n{3,}/g, '\n\n');
          if (!text) {
            setStatus('没有可复制内容');
            return;
          }
          try {
            await navigator.clipboard.writeText(text);
            setStatus('已复制');
          } catch (error) {
            setStatus('复制失败，请手动选中正文');
          }
        };

        button.addEventListener('click', copyArticle);
        window.addEventListener('keydown', (event) => {
          if (event.key?.toLowerCase() !== 'c' || event.ctrlKey || event.metaKey || event.altKey) return;
          const active = document.activeElement;
          if (active && ['INPUT', 'TEXTAREA', 'SELECT'].includes(active.tagName)) return;
          event.preventDefault();
          copyArticle();
        });
      })();
    </script>

    {/*
      广告位 B — 文章内容后（效果通常最好）
      申请通过后：替换 pub-XXXXXXXXXXXXXXXXX 和 data-ad-slot 值，删除注释
    */}
    {/* <ins class="adsbygoogle ad-article-bottom"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXXXX"
         data-ad-slot="BBBBBBBBBB"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script> */}

    {sources.length > 0 && (
      <aside class="sources" aria-label="信息来源">
        <p class="sources-heading">信息来源</p>
        <ul class="sources-list">
          {sources.map(s => (
            <li>
              <a href={s.url} target="_blank" rel="noopener noreferrer">{s.name}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    {(prevPost || nextPost) && (
      <nav class="post-nav" aria-label="相邻文章">
        {prevPost ? (
          <a href={`/blog/${prevPost.id}/`} rel="prev">
            <span>上一篇</span>
            <strong>{prevPost.data.title}</strong>
          </a>
        ) : <div></div>}
        {nextPost ? (
          <a href={`/blog/${nextPost.id}/`} rel="next">
            <span>下一篇</span>
            <strong>{nextPost.data.title}</strong>
          </a>
        ) : <div></div>}
      </nav>
    )}

  </div>
</BaseLayout>
